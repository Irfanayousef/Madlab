<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CASIO"
        android:id="@+id/casio"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginStart="300dp"
        android:textStyle="bold"
        android:textSize="30dp"
    />
    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/casio"
        android:layout_marginStart="320dp"
        android:layout_marginTop="15dp"
        android:id="@+id/text1"
        android:hint="0"
        android:gravity="end"
        />

    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/text1"
        android:id="@+id/btn1"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="50dp"
        android:text="1"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/text1"
        android:layout_toRightOf="@+id/btn1"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="50dp"
        android:id="@+id/btn2"
        android:text="2"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/text1"
        android:layout_toRightOf="@+id/btn2"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="50dp"
        android:id="@+id/btn3"
        android:text="3"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_below="@+id/text1"
        android:layout_toRightOf="@+id/btn3"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="50dp"
        android:id="@+id/btnp"
        android:text="+"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn1"
        android:id="@+id/btn4"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:text="4"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn2"
        android:layout_toRightOf="@+id/btn4"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btn5"
        android:text="5"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn3"
        android:layout_toRightOf="@+id/btn5"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btn6"
        android:text="6"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btnp"
        android:layout_toRightOf="@+id/btn6"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btnm"
        android:text="-"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn4"
        android:id="@+id/btn7"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:text="7"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn5"
        android:layout_toRightOf="@+id/btn7"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btn8"
        android:text="8"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn6"
        android:layout_toRightOf="@+id/btn5"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btn9"
        android:text="9"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btnm"
        android:layout_toRightOf="@+id/btn9"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btnd"
        android:text="/"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn7"
        android:id="@+id/btnk"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:text="."
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn8"
        android:layout_toRightOf="@+id/btnk"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btnz"
        android:text="0"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="70dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btn9"
        android:layout_toRightOf="@+id/btnz"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btnc"
        android:text="c"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btnd"
        android:layout_toRightOf="@+id/btnc"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="15dp"
        android:id="@+id/btnM"
        android:text="*"
        android:textSize="30sp"
        />
    <Button
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_below="@+id/btnk"
        android:id="@+id/btne"
        android:layout_centerHorizontal="true"
        android:textSize="30sp"
        android:text="="
        />





</RelativeLayout>